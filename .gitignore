# =============================================================
# .gitignore — agentic-arch
# =============================================================

# -------------------------------------------------------------
# Python
# -------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl

# Virtual environments
.venv/
venv/
env/
.env/
ENV/

# Environment variables
.env
.env.*
!.env.example


git-clean.md

# -------------------------------------------------------------
# MkDocs
# -------------------------------------------------------------
site/

# -------------------------------------------------------------
# Logs
# -------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*

# -------------------------------------------------------------
# Temp & cache
# -------------------------------------------------------------
tmp/
temp/
.tmp/
.cache/
*.tmp
*.bak
*.swp
*.swo
*~

# -------------------------------------------------------------
# OS
# -------------------------------------------------------------

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
.Trash-*

# -------------------------------------------------------------
# VS Code
# -------------------------------------------------------------
.vscode/settings.json
settings.json

# -------------------------------------------------------------
# JetBrains IDEs
# -------------------------------------------------------------
.idea/
*.iml

# -------------------------------------------------------------
# Node (in case tooling is added later)
# -------------------------------------------------------------
node_modules/
.npm/
package-lock.json
yarn.lock

# -------------------------------------------------------------
# Pandoc output (generated files)
# -------------------------------------------------------------
*.pdf
*.docx
*.odt
*.epub

# -------------------------------------------------------------
# Secrets & credentials
# -------------------------------------------------------------
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
